# ===== AutomaEyes — .gitignore =====

# Node.js dependencies (regenerate: npm install)
node_modules/

# Python virtual-env & cache (dibuat ulang oleh setup.bat)
python/ls-venv/
**/__pycache__/
*.pyc

# Model weights — besar, GitHub tolak file >100 MB
*.pt

# Output training & dataset per-model (besar, bisa dihasilkan ulang)
projects/*/models/*/runs/
projects/*/models/*/weights/
projects/*/models/*/dataset/images/
projects/*/models/*/dataset/labels/
projects/*/outputs/

# Log & temporary
*.log
_ls_install.log
Thumbs.db
.DS_Store
